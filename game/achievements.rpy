################################################################################
## КОНФИГУРАЦИЯ
################################################################################
## Это значение конфигурации определяет, должно ли внутриигровое всплывающее
## окно достижения появляться при обнаружении Steam. Поскольку в Steam уже есть
## собственное встроенное всплывающее окно, вы можете установить это значение
## в False, если не хотите показывать внутриигровое всплывающее окно вместе с ним.
## Внутриигровое всплывающее окно будет по-прежнему работать в сборках без Steam,
## например, в сборках, выпущенных DRM-free на itch.io.
define myconfig.INGAME_POPUP_WITH_STEAM = True
## Время, в течение которого внутриигровое всплывающее окно скрывается (см.
## трансформацию achievement_popout ниже).
define myconfig.ACHIEVEMENT_HIDE_TIME = 1.0
## True, если игра должна показывать внутриигровые всплывающие окна достижений,
## когда достижение получено. Вы можете установить это значение в False,
## если хотите только галерею достижений и не нуждаетесь во всплывающих окнах.
define myconfig.SHOW_ACHIEVEMENT_POPUPS = True
## Здесь можно указать звук, который будет воспроизводиться при появлении
## всплывающего окна достижения. None означает отсутствие звука.
define myconfig.ACHIEVEMENT_SOUND = "audio/sfx/achievement.ogg"
## Если звук воспроизводится, здесь указывается канал, на котором он будет
## играть. Аудиоканал воспроизводится на микшере sfx и может воспроизводить
## перекрывающиеся звуки, если несколько достижений получены одновременно.
define myconfig.ACHIEVEMENT_CHANNEL = "audio"
## Это имя и описание по умолчанию, используемые для скрытых достижений,
## если вы не укажете более конкретные. См. примеры ниже для того,
## как это сделать.
define myconfig.HIDDEN_ACHIEVEMENT_NAME = _("???{#hidden_achievement_name}")
define myconfig.HIDDEN_ACHIEVEMENT_DESCRIPTION = _("???{#hidden_achievement_description}")

## Это встроенное значение конфигурации. Оно устанавливает положение
## всплывающего окна Steam. Вы можете изменить его на любое из следующих:
## "top_left", "top_right", "bottom_left", "bottom_right"
## Возможно, вы захотите использовать это, чтобы уведомления Steam не
## конфликтовали с положением встроенного уведомления, если вы используете оба.
define achievement.steam_position = None

################################################################################
## ОПРЕДЕЛЕНИЕ ДОСТИЖЕНИЙ
################################################################################
## Замените это изображением заблокированного достижения, которое вы хотите
## использовать по умолчанию.
image locked_achievement = Text("?", color="#000000")

################################################################################
## Начало примеров объявления достижений и внутриигровых примеров.
## Вы можете удалить этот код до комментария "Конец примеров объявления достижений",
## если он вам не нужен - это просто примеры.
################################################################################
## Пример 1 ###################################################################
## Вот так вы объявляете достижения. Вы будете использовать `define`, а НЕ
## `default`, чтобы вы могли обновлять достижения позже (вы же не хотите,
## чтобы описание было привязано к конкретному файлу сохранения, например).
## Порядок, в котором вы объявляете достижения, - это порядок, в котором они
## будут отображаться в галерее достижений по умолчанию.
define sample_achievement = Achievement(
    ## Отображаемое имя, как оно будет показано во всплывающем окне и в галерее.
    name=_("Холод металла"),
    ## Идентификатор используется для интеграции со Steam и должен соответствовать
    ## тому идентификатору, который вы настроили в бэкенде Steam (если используете).
    id="sample_achievement",
    ## Описание.
    description=_("Вспомнить тепло чужой ладони, сжимая в руке холодный металл."),
    ## Изображение, используемое во всплывающем окне и в галерее после того,
    ## как это достижение будет разблокировано.
    unlocked_image="gui/window_icon.png",
    ## По умолчанию все достижения используют изображение "locked_achievement"
    ## (объявленное выше), но если вы хотите предоставить другое изображение,
    ## вот как это можно указать. Оно используется в галерее достижений,
    ## когда достижение заблокировано.
    locked_image="locked_achievement",
    ## По умолчанию для всех достижений установлены значения hide_name=False и
    ## hide_description=False, но вы можете изменить любое из них на True,
    ## чтобы скрыть имя или описание до разблокировки достижения. См. примеры
    ## 4-7 ниже для того, как это сделать.
    hide_name=False,
    hide_description=False,
)
## Вы можете выдать достижение в игре с помощью `$ sample_achievement.grant()`

## Пример 2 ###################################################################
define progress_achievement = Achievement(
    name=_("Прогрессивное достижение"),
    id="progress_achievement",
    description=_("Это достижение с индикатором прогресса."),
    unlocked_image=Transform("gui/window_icon.png", matrixcolor=InvertMatrix()),
    ## Для отслеживания прогресса необходимо указать stat_max. Это означает,
    ## что вы можете показывать индикатор выполнения с процентом завершения
    ## достижения. Это полезно, если, например, у вас есть достижение,
    ## подсчитывающее, сколько глав прошел игрок, и оно открывается,
    ## когда он увидел все главы.
    stat_max=12,
    ## Вы также можете указать stat_modulo, что означает, что достижение
    ## обновляется в бэкенде Steam только каждый раз, когда значение
    ## достигает кратного модулю.
    ## В качестве альтернативы эта система также позволяет вам установить
    ## stat_update_percent, поэтому, если вы хотите, чтобы оно обновлялось
    ## каждые 10% прогресса, вы можете установить
    # stat_update_percent=10
    ## Это наиболее полезно для достижений с большим количеством шагов,
    ## например, для достижения общего процента завершения. Возможно,
    ## для достижения нужно выполнить 600 действий, но, очевидно,
    ## приращения в 0,1% мало что значат, поэтому вы можете либо установить
    ## stat_modulo=6, либо stat_update_percent=1, и оно будет обновлять
    ## Steam каждые 6 шагов или каждый 1%.
    ## Внутриигровая шкала/цифры будут обновляться при каждом увеличении.
    ##
    ## Это показывает индикатор прогресса в галерее. По умолчанию это True,
    ## если у вас есть stat_max, но вы можете установить значение False,
    ## если не хотите показывать шкалу (но хотите отслеживать прогресс).
    show_progress_bar=True,
)
## Чтобы обновить прогресс выполнения этого достижения, вы можете использовать
# $ progress_achievement.add_progress(1)
## где 1 - это объем прогресса, добавляемый к статистике (таким образом,
## при первом вызове для приведенного выше примера это будет 1/12,
## при втором - 2/12 и т.д.).
##
## В качестве альтернативы вы можете напрямую установить прогресс следующим образом:
# $ progress_achievement.progress(5)
## Это напрямую установит прогресс на 5, сделав приведенный выше пример
## 5/12. В качестве альтернативы вы можете воспользоваться встроенной
## функциональностью "набора", описанной ниже.

## Пример 3 ###################################################################
define set_progress_achievement = Achievement(
    name=_("Прогрессивное достижение с набором"),
    id="set_progress_achievement",
    description=_("Это достижение с прогрессом, но без индикатора."),
    unlocked_image=Transform("gui/window_icon.png", matrixcolor=HueMatrix(270)),
    ## Это устанавливает статистику для прогресса
    stat_max=3,
    show_progress_bar=False, # Не показывать индикатор прогресса в галерее
    # (хотя оно все равно отслеживает статистику)
)
## Помимо методов add_progress и progress, описанных выше, вы также можете
## использовать метод add_set_progress для добавления значения в набор,
## привязанный к этому достижению. Наборы уникальны - поэтому, если вы
## попытаетесь добавить одно и то же значение дважды, оно окажется в наборе
## только один раз. Это означает, что вам не нужно проверять, находится ли
## что-то уже в наборе, перед добавлением.
## Вы можете использовать это для отслеживания уникальных флагов в сторону
## прогресса этого достижения.
## Например, предположим, вы добавляете в свою игру хорошую, плохую и
## нейтральную концовки. В этих концовках у вас была бы одна из следующих строк:
## $ set_progress_achievement.add_set_progress("good_end")
## $ set_progress_achievement.add_set_progress("bad_end")
## $ set_progress_achievement.add_set_progress("neutral_end")
## Когда игрок увидит все 3 концовки, в наборе достижения будет 3 уникальных
## значения, поэтому достижение автоматически разблокируется, как только
## они получат третье (неважно, в каком порядке они их увидят).
## Обратите внимание, что набор не ограничен stat_max - вы можете добавить
## в него 10 уникальных значений, но достижение разблокируется после того,
## как в нем будет 3 уникальных значения.
## Это может быть полезно, если у вас, скажем, 20 предметов коллекционирования
## в игре, но для достижения требуется только 15 из них.
## См. примерную метку после Примера 8 для некоторых внутриигровых примеров
## того, как это может выглядеть.


## Пример 5 ###################################################################
